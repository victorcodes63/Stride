# Stride public marketing site — getstride.co.ke
# Apply on the Vercel project serving the marketing domain (may be same repo as Stride).

NEXT_PUBLIC_SITE_URL="https://getstride.co.ke"
NEXT_PUBLIC_MARKETING_DOMAIN="getstride.co.ke"
NEXT_PUBLIC_APP_ORIGIN="https://app.getstride.co.ke"

# Product identity (public surfaces)
NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_ORG_NAME="Stride"
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_BRAND_LOGO="/brand/stride-mark.svg"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/stride-mark.svg"
NEXT_PUBLIC_BRAND_WORDMARK="/brand/stride-wordmark.svg"

# Marketing-only deploy: no tenant names or demo credentials on public login (RAV-169)
SITE_MODE="marketing"
DEMO_MODE="false"
NEXT_PUBLIC_DEMO_MODE="false"
NEXT_PUBLIC_SHOW_DEMO_LOGIN_HINT="false"
NEXT_PUBLIC_GENERIC_PUBLIC_LOGIN="true"
# Demo sandbox is internal-only — never advertise on public marketing
NEXT_PUBLIC_DEMO_ACCESS_PAGE="false"
NEXT_PUBLIC_INTERNAL_DEMO_SANDBOX="false"

# Book demo leads — configure for production (RAV-49)
# SMTP_* or Resend — see .env.example
