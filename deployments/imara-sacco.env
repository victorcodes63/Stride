# Imara — SACCO beachhead demo (Phase 1 wedge: People + Time + Payroll)
# Apply: npm run demo:reseed:imara-sacco

DEMO_PACK=imara-sacco
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Product identity (Imara Vertical BMS)
NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_ORG_NAME="Heritage Members SACCO Ltd"
NEXT_PUBLIC_APP_TAGLINE="Hit your stride. HR, finance, and operations on one platform — built for East African businesses."
NEXT_PUBLIC_BRAND_LOGO="/brand/stride-mark.png"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/stride-mark.png"
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_RECRUITMENT_EMPLOYER_NAME="Heritage Members SACCO Ltd"
NEXT_PUBLIC_SITE_URL="https://hcm.raventechgroup.com"

# Demo login (matches imara-sacco pack seed — reseed after domain change)
STAFF_ALLOWED_DOMAIN="heritage.demo.getstride.co.ke,demo.getstride.co.ke,example.com"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="admin@demo.getstride.co.ke"
NEXT_PUBLIC_DEMO_HR_EMAIL="hr.demo@heritage.demo.getstride.co.ke"
NEXT_PUBLIC_DEMO_APPROVER_EMAIL="hr.demo@heritage.demo.getstride.co.ke"
NEXT_PUBLIC_DEMO_STAFF_EMAIL="james.otieno@eaglehr.co.ke"
NEXT_PUBLIC_DEMO_FINANCE_EMAIL="finance@heritage.demo.getstride.co.ke"
NEXT_PUBLIC_DEMO_ESS_EMAIL="employee@heritage.demo.getstride.co.ke"
NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
STAFF_PASSWORD="Demo@2026!"

# Unified admin across all verticals (multi-context switcher)
DEMO_UNIFIED_ADMIN_EMAIL="admin@demo.getstride.co.ke"

# Sales demo: full platform (People, Payroll, Talent, Finance, HSE, Assets, SACCO, …)
MODULE_SACCO=true
