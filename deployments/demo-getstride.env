# Demo cell — demo.getstride.co.ke (SwiftFreight showcase, isolated Neon)
# Apply: node scripts/setup-demo-getstride-vercel.mjs
# Seed DB: npm run demo:cell:provision

SITE_MODE="app"
NEXT_PUBLIC_SITE_URL="https://demo.getstride.co.ke"
NEXT_PUBLIC_APP_ORIGIN="https://demo.getstride.co.ke"
NEXTAUTH_URL="https://demo.getstride.co.ke"

NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_BRAND_LOGO="/brand/stride-mark.svg"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/stride-mark.svg"
NEXT_PUBLIC_APP_TAGLINE="Fleet, warehouse, and dispatch operations — payroll and compliance for logistics teams."

# Demo sandbox — SwiftFreight cargo-logistics vertical
DEMO_MODE="true"
DEMO_PACK="cargo-logistics"
NEXT_PUBLIC_DEMO_MODE="true"
NEXT_PUBLIC_ORG_NAME="SwiftFreight East Africa Ltd"
NEXT_PUBLIC_RECRUITMENT_EMPLOYER_NAME="SwiftFreight East Africa Ltd"
NEXT_PUBLIC_SHOW_DEMO_LOGIN_HINT="true"
NEXT_PUBLIC_TENANT_LOGIN_BRANDING="true"
NEXT_PUBLIC_DEMO_ACCESS_PAGE="false"
MULTI_ENTITY_ENABLED="false"

STAFF_ALLOWED_DOMAIN="swiftfreight.imara.co.ke,imara.co.ke,example.com"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="admin@imara.co.ke"
NEXT_PUBLIC_DEMO_HR_EMAIL="hr@swiftfreight.imara.co.ke"
NEXT_PUBLIC_DEMO_APPROVER_EMAIL="hr@swiftfreight.imara.co.ke"
NEXT_PUBLIC_DEMO_FINANCE_EMAIL="finance@swiftfreight.imara.co.ke"
NEXT_PUBLIC_DEMO_ESS_EMAIL="moses.okello@swiftfreight.imara.co.ke"
NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
STAFF_PASSWORD="Demo@2026!"
DEMO_UNIFIED_ADMIN_EMAIL="admin@imara.co.ke"

RUN_MIGRATIONS_ON_BUILD="false"

# Required for control-plane Users tab + org lookup (same value as control-plane):
# STRIDE_CELL_PROVISION_KEY=

# Set on Vercel from .env.demo-cell.local (isolated Neon — not app.getstride.co.ke):
# DATABASE_URL=
# DIRECT_DATABASE_URL=
