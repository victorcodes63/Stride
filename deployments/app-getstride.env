# Stride platform — app.getstride.co.ke (customer cell)
# Apply on the Vercel project serving the product domain (NOT stride-app marketing).
# Demo vars belong on demo.getstride.co.ke only — see docs/VICTOR-TODO-ISO-01-DEMO-SPLIT.md

SITE_MODE="app"
NEXT_PUBLIC_SITE_URL="https://app.getstride.co.ke"
NEXT_PUBLIC_APP_ORIGIN="https://app.getstride.co.ke"
# Do not set NEXT_PUBLIC_MARKETING_DOMAIN on the app deploy.

NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_BRAND_LOGO="/brand/stride-mark.svg"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/stride-mark.svg"

NEXT_PUBLIC_TENANT_LOGIN_BRANDING="true"
NEXT_PUBLIC_DEMO_ACCESS_PAGE="false"
RUN_MIGRATIONS_ON_BUILD="true"

# Copy from your Neon / Postgres project:
# DATABASE_URL=
# DIRECT_DATABASE_URL=  (or DATABASE_URL_UNPOOLED)
